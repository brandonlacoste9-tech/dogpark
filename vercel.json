{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
        { "source": "/ads.txt", "destination": "/site/ads.txt", "permanent": false },
    { "source": "/", "destination": "/site/", "permanent": true },
    { "source": "/site", "destination": "/site/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/site/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/site/data/parks.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }]
    },
    {
      "source": "/site/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=120, stale-while-revalidate=3600" }]
    },
    {
      "source": "/site/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=120, stale-while-revalidate=3600" }]
    },
    {
      "source": "/site/(.*).svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    }
  ]
}
