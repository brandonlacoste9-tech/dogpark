{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/", "destination": "/site/", "permanent": true },
    { "source": "/site", "destination": "/site/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/ads.txt", "destination": "/site/ads.txt" },
    { "source": "/privacy", "destination": "/site/privacy.html" },
    { "source": "/privacy.html", "destination": "/site/privacy.html" }
  ],
  "headers": [
    {
      "source": "/site/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/site/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/site/data/parks.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }]
    },
    {
      "source": "/site/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=120, stale-while-revalidate=3600" }]
    },
    {
      "source": "/site/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=120, stale-while-revalidate=3600" }]
    },
    {
      "source": "/site/(.*).svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    }
  ]
}
